# ===== Poker Trainer environment =====
# Copy this file to `.env` (in the project root) and fill in values, OR
# export these vars in your shell. The Python process reads from os.environ
# at startup; both ways work.
#
# Pick ONE provider via LLM_PROVIDER, then fill the matching block below.

# Provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic


# ===== Anthropic (Claude) =====
# Use ONE of:
#  (a) Official Anthropic API: set ANTHROPIC_API_KEY only.
#  (b) Anthropic-compatible relay (e.g. mify, OpenRouter Anthropic mode):
#      set ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN.

ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://your-relay.example.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your-relay-token

# Model id. Defaults to "claude-opus-4-5". Override if your relay needs a
# different id (e.g. "ppio/pa/claude-opus-4-7" on mify).
# POKER_AI_MODEL=claude-opus-4-5


# ===== OpenAI (GPT) =====
# Used when LLM_PROVIDER=openai. Works with any OpenAI-compatible endpoint
# (Azure OpenAI, OpenRouter, local LM Studio, etc) by setting OPENAI_BASE_URL.

# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
